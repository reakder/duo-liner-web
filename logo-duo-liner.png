<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Ingresar | DUO-LINER</title><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet"><link rel="stylesheet" href="assets/styles.css"></head><body class="login-body"><div class="login-shell"><a href="index.html"><img src="logo-duo-liner.png" class="login-logo" alt="DUO-LINER"></a><div class="login-card"><p class="section-title-small">Sistema interno</p><h1>Ingresar</h1><p class="login-help">Demo inicial. Usuario: <b>admin</b> / Clave: <b>1234</b></p><input id="user" placeholder="Usuario" autocomplete="username"><input id="pass" type="password" placeholder="Contraseña" autocomplete="current-password"><button class="btn-form" onclick="login()">Ingresar</button><p id="error" class="form-error"></p></div></div><script src="assets/app.js"></script></body></html>
